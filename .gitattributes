# Normalize line endings
* text=auto eol=lf

# Godot text formats — keep LF
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.cfg text eol=lf
*.import text eol=lf

# Shell / CI
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.wav binary
*.ogg binary
*.mp3 binary
*.ttf binary
*.otf binary
